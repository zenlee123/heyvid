  "description": "A TypeScript toolkit with prompt presets and workflow helpers for creating AI video and image briefs with HeyVid.",
  "author": "HeyVid community",
  "license": "MIT",
  "type": "module",
  "homepage": "https://heyvid.ai",
  "repository": {
